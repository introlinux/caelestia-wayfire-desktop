#!/usr/bin/env python3
"""Set Wayfire config options at runtime via IPC.

Usage: caelestia-wayfire-opt <section/option>=<value> [more...]
Example: caelestia-wayfire-opt ninjaslash/sound_enabled=false

Uses `wayfire/set-config-options` (ipc-rules plugin). Note this only changes
the running compositor: it does NOT write wayfire.ini, and Wayfire locks the
option afterwards, so the caller is the source of truth and should re-apply
the value on startup.

Exits 0 on success. Missing compositor or unknown option exits 1, quietly
enough to be safe to call from the shell on every toggle.
"""
import sys, os, socket, json, struct, glob


def ipc(sock_path, method, data=None):
    s = socket.socket(socket.AF_UNIX)
    s.settimeout(2.0)
    try:
        s.connect(sock_path)
        payload = {'method': method}
        if data is not None:
            payload['data'] = data
        msg = json.dumps(payload).encode()
        s.send(struct.pack('<I', len(msg)) + msg)
        hdr = s.recv(4)
        if len(hdr) < 4:
            return None
        n = struct.unpack('<I', hdr)[0]
        resp = b''
        while len(resp) < n:
            chunk = s.recv(n - len(resp))
            if not chunk:
                return None
            resp += chunk
        return json.loads(resp)
    finally:
        s.close()


def main():
    args = sys.argv[1:]
    if not args:
        print(__doc__, file=sys.stderr)
        sys.exit(2)

    options = {}
    for arg in args:
        if '=' not in arg:
            print(f'bad argument (expected name=value): {arg}', file=sys.stderr)
            sys.exit(2)
        name, value = arg.split('=', 1)
        options[name] = value

    sock = os.environ.get('WAYFIRE_SOCKET', '')
    if not sock or not os.path.exists(sock):
        uid = os.getuid()
        sockets = glob.glob(f'/run/user/{uid}/wayfire*.socket')
        if not sockets:
            print('no wayfire socket', file=sys.stderr)
            sys.exit(1)
        sock = sockets[0]

    try:
        r = ipc(sock, 'wayfire/set-config-options', options)
    except OSError as e:
        print(f'ipc failed: {e}', file=sys.stderr)
        sys.exit(1)

    if not isinstance(r, dict) or r.get('result') != 'ok':
        print(f'wayfire refused: {r}', file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
