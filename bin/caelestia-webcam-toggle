#!/usr/bin/env python3
"""caelestia-webcam-toggle: conmuta un recuadro flotante con la webcam.

Para videotutoriales (atajo: Super+W). Primera invocación: abre ffplay con
la webcam (sin bordes, app-id "caelestia-webcam" vía SDL), lo coloca en la
esquina inferior derecha del workarea del output enfocado y lo deja
siempre-encima + sticky (visible en todos los workspaces) vía IPC de
Wayfire (ipc-rules + wm-actions). Segunda invocación: lo cierra.

El dispositivo se puede cambiar con CAELESTIA_WEBCAM_DEV (por defecto
/dev/video0, la Logitech C270). Tamaño y margen en las constantes.

Subcomandos (solo con mpv, en vivo vía su IPC):
  caelestia-webcam-toggle mirror   cicla los 4 volteos sin reiniciar la
                                   cámara: normal -> espejo horizontal
                                   (enseñar libros/texto a cámara) ->
                                   volteo vertical -> ambos (180) -> normal
"""

import glob
import json
import os
import signal
import socket
import struct
import subprocess
import sys
import time

WIDTH = 480      # tamaño del recuadro en pantalla (la captura va a 640x480)
HEIGHT = 360
MARGIN = 16      # separación de las esquinas del workarea
APP_ID = 'caelestia-webcam'
DEVICE = os.environ.get('CAELESTIA_WEBCAM_DEV', '/dev/video0')
PIDFILE = os.path.join(os.environ.get('XDG_RUNTIME_DIR', '/tmp'),
                       'caelestia-webcam.pid')
MPVSOCK = os.path.join(os.environ.get('XDG_RUNTIME_DIR', '/tmp'),
                       'caelestia-webcam-mpv.sock')
FLIPFILE = os.path.join(os.environ.get('XDG_RUNTIME_DIR', '/tmp'),
                        'caelestia-webcam.flip')
# Ciclo de `mirror`: filtros de video de cada posicion, en orden
FLIP_STATES = ['', 'hflip', 'vflip', 'hflip,vflip']


class Ipc:
    def __init__(self, sock_path):
        self.s = socket.socket(socket.AF_UNIX)
        self.s.connect(sock_path)

    def call(self, method, data=None):
        payload = {'method': method}
        if data is not None:
            payload['data'] = data
        msg = json.dumps(payload).encode()
        self.s.send(struct.pack('<I', len(msg)) + msg)
        n = struct.unpack('<I', self.s.recv(4))[0]
        resp = b''
        while len(resp) < n:
            resp += self.s.recv(n - len(resp))
        return json.loads(resp)


def find_socket():
    sock = os.environ.get('WAYFIRE_SOCKET', '')
    if sock:
        return sock
    sockets = glob.glob(f'/run/user/{os.getuid()}/wayfire*.socket')
    if not sockets:
        sys.exit('caelestia-webcam-toggle: no Wayfire IPC socket found')
    return sockets[0]


def notify(msg):
    subprocess.run(['notify-send', '-a', 'Webcam', 'Webcam', msg],
                   stdin=subprocess.DEVNULL, check=False)


def running_pid():
    try:
        pid = int(open(PIDFILE).read())
        os.kill(pid, 0)
        return pid
    except (OSError, ValueError):
        return None


def mpv_command(*args):
    """Manda un comando al mpv en marcha por su socket IPC."""
    if not running_pid() or not os.path.exists(MPVSOCK):
        notify('La webcam no está encendida (o corre con ffplay, sin IPC)')
        sys.exit(1)
    c = socket.socket(socket.AF_UNIX)
    c.connect(MPVSOCK)
    c.send((json.dumps({'command': list(args)}) + '\n').encode())
    c.close()


def cycle_mirror():
    try:
        state = (int(open(FLIPFILE).read()) + 1) % len(FLIP_STATES)
    except (OSError, ValueError):
        state = 1
    vf = FLIP_STATES[state]
    mpv_command('vf', 'set', vf) if vf else mpv_command('vf', 'clr', '')
    with open(FLIPFILE, 'w') as f:
        f.write(str(state))


def main():
    if len(sys.argv) > 1:
        sub = sys.argv[1]
        if sub == 'mirror':
            return cycle_mirror()
        sys.exit(f'caelestia-webcam-toggle: subcomando desconocido {sub!r} '
                 '(disponibles: mirror)')

    pid = running_pid()
    if pid:
        os.kill(pid, signal.SIGTERM)
        os.unlink(PIDFILE)
        # el ciclo de mirror muere con el proceso: proxima sesion, normal
        try:
            os.unlink(FLIPFILE)
        except OSError:
            pass
        return

    if not os.path.exists(DEVICE):
        notify(f'No se encuentra la cámara ({DEVICE})')
        sys.exit(1)

    # Se prefiere mpv: es redimensionable en vivo (Alt+arrastre derecho, o
    # configure-view). ffplay queda de respaldo, pero su ventana SDL sin
    # borde es de tamano fijo (y con borde ni llega a mapear en Wayfire),
    # asi que con ffplay solo se puede mover, no redimensionar.
    import shutil
    env = dict(os.environ, SDL_VIDEODRIVER='wayland', SDL_APP_ID=APP_ID)
    if shutil.which('mpv'):
        cmd = ['mpv', '--really-quiet', '--profile=low-latency', '--untimed',
               '--no-border', '--no-osc', '--title=Webcam',
               f'--wayland-app-id={APP_ID}', f'--geometry={WIDTH}x{HEIGHT}',
               f'--input-ipc-server={MPVSOCK}',
               # Volteos permanentes (los subcomandos mirror/flipv los
               # conmutan en vivo, pero si quieres arrancar siempre asi,
               # descomenta el que toque):
               # '--vf=hflip',        # espejo horizontal
               # '--vf=vflip',        # volteo vertical
               # '--vf=hflip,vflip',  # ambos (equivale a girar 180 grados)
               f'av://v4l2:{DEVICE}']
    else:
        cmd = ['ffplay', '-hide_banner', '-loglevel', 'error', '-noborder',
               '-x', str(WIDTH), '-y', str(HEIGHT),
               '-window_title', 'Webcam', '-fflags', 'nobuffer', '-flags',
               'low_delay', '-f', 'v4l2', '-framerate', '30', '-video_size',
               '640x480', '-i', DEVICE]
    proc = subprocess.Popen(
        cmd, env=env, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL, start_new_session=True)
    with open(PIDFILE, 'w') as f:
        f.write(str(proc.pid))

    # Espera a que la vista aparezca en el compositor para colocarla
    ipc = Ipc(find_socket())
    view = None
    deadline = time.monotonic() + 6
    while time.monotonic() < deadline:
        if proc.poll() is not None:   # ffplay murio (camara ocupada, etc.)
            os.unlink(PIDFILE)
            notify('ffplay no pudo abrir la cámara (¿en uso?)')
            sys.exit(1)
        # mpv respeta --wayland-app-id; el SDL de Ubuntu ignora SDL_APP_ID y
        # deja app-id "ffplay", de ahi el segundo criterio con el titulo.
        for v in ipc.call('window-rules/list-views'):
            if (v.get('mapped') and (v.get('app-id') == APP_ID
                    or (v.get('app-id') == 'ffplay' and v.get('title') == 'Webcam'))):
                view = v
                break
        if view:
            break
        time.sleep(0.1)
    if not view:
        proc.terminate()
        os.unlink(PIDFILE)
        notify('La ventana de la webcam no llegó a aparecer')
        sys.exit(1)

    out = ipc.call('window-rules/get-focused-output')
    out = out.get('info', out)   # la respuesta viene envuelta en "info"
    wa = out['workarea']
    geometry = {
        'x': wa['x'] + wa['width'] - WIDTH - MARGIN,
        'y': wa['y'] + wa['height'] - HEIGHT - MARGIN,
        'width': WIDTH,
        'height': HEIGHT,
    }
    # El siempre-encima lo aplica la regla estatica de wayfire.ini
    # (webcam_ontop en [window-rules]); wm-actions no expone IPC en 0.10.1.
    ipc.call('window-rules/configure-view',
             {'id': view['id'], 'geometry': geometry, 'sticky': True})


if __name__ == '__main__':
    main()
