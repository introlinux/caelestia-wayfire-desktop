#!/usr/bin/env python3
"""Switch Wayfire workspace and notify Quickshell about the change."""
import sys, socket, json, struct, time, os, subprocess

def ipc(sock_path, method, data=None):
    s = socket.socket(socket.AF_UNIX)
    s.connect(sock_path)
    payload = {'method': method}
    if data is not None:
        payload['data'] = data
    msg = json.dumps(payload).encode()
    s.send(struct.pack('<I', len(msg)) + msg)
    time.sleep(0.1)
    header = s.recv(4)
    length = struct.unpack('<I', header)[0]
    resp = s.recv(max(length, 1))
    s.close()
    return json.loads(resp)

sock = os.environ.get('WAYFIRE_SOCKET', '')
if not sock:
    import glob
    uid = os.getuid()
    sockets = glob.glob(f'/run/user/{uid}/wayfire*.socket')
    sock = sockets[0] if sockets else f'/run/user/{uid}/wayfire-wayland-1-.socket'
ws_n = int(sys.argv[1])  # 1-based workspace number

# Grid: 4 columns × 1 row
x = (ws_n - 1) % 4
y = (ws_n - 1) // 4

# Try output IDs until one works
for output_id in range(1, 10):
    result = ipc(sock, 'vswitch/set-workspace', {'x': x, 'y': y, 'output-id': output_id})
    if result.get('result') == 'ok':
        break

# Notify Quickshell so the workspace indicator updates
subprocess.Popen(
    ['qs-caelestia', 'hypr', 'setActiveWs', str(ws_n)],
    close_fds=True,
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
)
