#!/bin/bash
# Launcher for Quickshell/Caelestia in a real Wayfire session.
# QML_IMPORT_PATH must point to the Qt6 QML dir so Caelestia modules are found.
# In Hyprland this comes from the environment; in a GDM session it is not set.
# GDM does not include ~/.local/bin in PATH; add it so app2unit and other helpers are found.
export PATH="__HOME__/.local/bin:$PATH"
export QML_IMPORT_PATH=/usr/lib/qt6/qml
export QT_QPA_PLATFORM=wayland
export QT_QPA_PLATFORMTHEME=gtk3

# Launch by config NAME (not path) so `qs -c caelestia ipc ...` — and therefore
# the upstream `caelestia` CLI — can find the instance. Quickshell matches
# instances by the literal -c argument, so the name must be identical on both
# sides. ~/.config/quickshell/caelestia is a symlink to ~/.caelestia/caelestia-wayfire
# (created by install.sh).
exec /usr/local/bin/quickshell -c caelestia \
    >> /tmp/caelestia-qs.log 2>&1
