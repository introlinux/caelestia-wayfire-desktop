#!/usr/bin/env python3
"""Capture a thumbnail of a Wayfire view via IPC.

Matches the view by app_id + title (exact title match preferred, app_id-only
as fallback) using `window-rules/list-views` (ipc-rules plugin), then asks
`view-shot/capture` (view-shot plugin, wayfire-plugins-extra) to write a PNG.

Usage: caelestia-view-thumb <app_id> <title> <outfile>
Prints the outfile path on success; exits 1 on failure.
"""
import sys, os, socket, json, struct, glob


def ipc(sock_path, method, data=None):
    s = socket.socket(socket.AF_UNIX)
    s.connect(sock_path)
    payload = {'method': method}
    if data is not None:
        payload['data'] = data
    msg = json.dumps(payload).encode()
    s.send(struct.pack('<I', len(msg)) + msg)
    hdr = s.recv(4)
    n = struct.unpack('<I', hdr)[0]
    resp = b''
    while len(resp) < n:
        resp += s.recv(n - len(resp))
    s.close()
    return json.loads(resp)


def main():
    if len(sys.argv) < 4:
        sys.exit(1)
    app_id, title, out = sys.argv[1], sys.argv[2], sys.argv[3]

    sock = os.environ.get('WAYFIRE_SOCKET', '')
    if not sock:
        uid = os.getuid()
        sockets = glob.glob(f'/run/user/{uid}/wayfire*.socket')
        if not sockets:
            sys.exit(1)
        sock = sockets[0]

    views = ipc(sock, 'window-rules/list-views')
    if not isinstance(views, list):
        sys.exit(1)

    candidates = [v for v in views
                  if v.get('role') == 'toplevel' and v.get('mapped', True)]
    best = next((v for v in candidates
                 if v.get('app-id') == app_id and v.get('title') == title), None)
    if best is None:
        best = next((v for v in candidates if v.get('app-id') == app_id), None)
    if best is None:
        sys.exit(1)

    r = ipc(sock, 'view-shot/capture', {'view-id': best['id'], 'file': out})
    if r.get('result') != 'ok':
        sys.exit(1)
    print(out, flush=True)


if __name__ == '__main__':
    main()
