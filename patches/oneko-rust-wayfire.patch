+// Global cursor position in screen (layout) coordinates, via Wayfire's IPC
+// socket (requires the ipc + ipc-rules plugins; method
+// window-rules/get_cursor_position replies {"result":"ok","pos":{"x":..,"y":..}}
+// in the same layout coordinates Hyprland's cursorpos used). This is the one
+// compositor-specific dependency in the whole program. The connection is kept
+// open across ticks and silently re-established if Wayfire restarts. Returns
+// (0, 0) if the socket isn't available or the reply can't be parsed.
+struct CursorIpc {
+    stream: Option<std::os::unix::net::UnixStream>,
+}
+
+impl CursorIpc {
+    fn new() -> Self {
+        CursorIpc { stream: None }
+    }
+
+    // $WAYFIRE_SOCKET when launched from within the session, otherwise scan
+    // $XDG_RUNTIME_DIR for wayfire-*.socket (there's one per compositor run).
+    fn socket_path() -> Option<std::path::PathBuf> {
+        if let Ok(path) = std::env::var("WAYFIRE_SOCKET") {
+            return Some(path.into());
+        }
+        let dir = std::env::var("XDG_RUNTIME_DIR").ok()?;
+        std::fs::read_dir(dir)
+            .ok()?
+            .filter_map(|e| e.ok())
+            .map(|e| e.path())
+            .find(|p| {
+                p.file_name()
+                    .and_then(|n| n.to_str())
+                    .map_or(false, |n| n.starts_with("wayfire") && n.ends_with(".socket"))
+            })
+    }
+
+    fn connect() -> Option<std::os::unix::net::UnixStream> {
+        let stream = std::os::unix::net::UnixStream::connect(Self::socket_path()?).ok()?;
+        // Bounded so a stalled compositor can't wedge the animation loop.
+        let timeout = Some(Duration::from_millis(250));
+        stream.set_read_timeout(timeout).ok()?;
+        stream.set_write_timeout(timeout).ok()?;
+        Some(stream)
+    }
+
+    // Wayfire IPC framing, both directions: u32 LE payload length + JSON.
+    fn query(&mut self) -> Option<(f32, f32)> {
+        use std::io::{Read, Write};
+        if self.stream.is_none() {
+            self.stream = Self::connect();
+        }
+        let stream = self.stream.as_mut()?;
+        let msg: &[u8] = br#"{"method":"window-rules/get_cursor_position","data":{}}"#;
+        let mut packet = Vec::with_capacity(4 + msg.len());
+        packet.extend_from_slice(&(msg.len() as u32).to_le_bytes());
+        packet.extend_from_slice(msg);
+        let reply = (|| {
+            stream.write_all(&packet).ok()?;
+            let mut len_buf = [0u8; 4];
+            stream.read_exact(&mut len_buf).ok()?;
+            let len = u32::from_le_bytes(len_buf) as usize;
+            if len > (1 << 20) {
+                return None; // desynced framing; force a reconnect
+            }
+            let mut buf = vec![0u8; len];
+            stream.read_exact(&mut buf).ok()?;
+            String::from_utf8(buf).ok()
+        })();
+        let Some(reply) = reply else {
+            self.stream = None;
+            return None;
+        };
+        let pos = &reply[reply.find("\"pos\"")?..];
+        Some((json_number(pos, "\"x\":")?, json_number(pos, "\"y\":")?))
+    }
+}
+
+// Extracts the number right after `key` (e.g. `"x":`) from a JSON snippet.
+// Enough for the fixed reply shape above; spares a serde dependency.
+fn json_number(s: &str, key: &str) -> Option<f32> {
+    let rest = s[s.find(key)? + key.len()..].trim_start();
+    let end = rest
+        .find(|c: char| !c.is_ascii_digit() && !"-+.eE".contains(c))
+        .unwrap_or(rest.len());
+    rest[..end].parse().ok()
 }
 
