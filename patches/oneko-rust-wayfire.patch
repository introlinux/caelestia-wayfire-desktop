+// Runtime-tunable behavior, parsed once from the command line in main().
+// Defaults match the original hardcoded values (except stop_distance,
+// which used to be 0: the cat parked right under the pointer, and since
+// its input region sat under the cursor it swallowed scroll/click events
+// meant for the window below).
+#[derive(Clone, Copy)]
+struct Config {
+    speed: f32,         // easing fraction per tick (0..1); higher = snappier cat
+    interval_ms: u64,   // tick length; lower = faster animation AND chase
+    radius: f32,        // cursor must come this close to wake the cat up
+    stop_distance: f32, // cat parks this many px short of the pointer
+    click_through: bool, // empty input region: cat never intercepts input (no click-to-freeze)
+}
+
+const HELP: &str = "\
+oneko-rust (Wayfire port): a desktop cat that chases your cursor.
+
+Options:
+  --speed <0.05-1.0>   easing per tick, fraction of remaining distance (default 0.3)
+  --interval <ms>      animation tick length; also scales chase speed and
+                       idle-timing (default 125)
+  --radius <px>        wake-up distance: cursor movement farther away than
+                       this is ignored (default 150)
+  --distance <px>      how far short of the pointer the cat stops, so it
+                       never sits under the cursor stealing scroll/click
+                       events (default 40; 0 = classic touch-the-pointer)
+  --click-through      never receive input at all (disables click-to-freeze)
+  -h, --help           show this help
+";
+
+impl Config {
+    fn from_args() -> Config {
+        let mut cfg = Config {
+            speed: 0.3,
+            interval_ms: 125,
+            radius: 150.0,
+            stop_distance: 40.0,
+            click_through: false,
+        };
+        let mut args = std::env::args().skip(1);
+        while let Some(arg) = args.next() {
+            let mut num = |name: &str| -> f32 {
+                args.next().and_then(|v| v.parse().ok()).unwrap_or_else(|| {
+                    eprintln!("oneko: {name} needs a numeric value (see --help)");
+                    std::process::exit(2);
+                })
+            };
+            match arg.as_str() {
+                "--speed" => cfg.speed = num("--speed").clamp(0.05, 1.0),
+                "--interval" => cfg.interval_ms = num("--interval").max(30.0) as u64,
+                "--radius" => cfg.radius = num("--radius").max(0.0),
+                "--distance" => cfg.stop_distance = num("--distance").max(0.0),
+                "--click-through" => cfg.click_through = true,
+                "-h" | "--help" => {
+                    print!("{HELP}");
+                    std::process::exit(0);
+                }
+                other => {
+                    eprintln!("oneko: unknown option '{other}' (see --help)");
+                    std::process::exit(2);
+                }
+            }
+        }
+        cfg
+    }
+}
 
